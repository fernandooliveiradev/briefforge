# Default AI provider selected in the creation UI: openai, deepseek, or openrouter.
AI_PROVIDER=openai

# OpenAI settings.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek settings.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenRouter settings.
# Set any OpenRouter model slug here. Free examples:
# - google/gemma-4-26b-a4b-it:free
# - google/gemma-4-31b-it:free
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemma-4-26b-a4b-it:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=BriefForge

# Optional access gate for deployed instances.
# Leave empty for local-only development. Set in production to protect private routes and project APIs.
BRIEFFORGE_ACCESS_PASSWORD=
BRIEFFORGE_SESSION_SECRET=
