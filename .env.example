# Default AI provider selected in the creation UI: openai or deepseek.
AI_PROVIDER=openai

# OpenAI settings.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_BASE_URL=https://api.openai.com/v1

# DeepSeek settings.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Optional access gate for deployed instances.
# Leave empty for local-only development. Set in production to protect private routes and project APIs.
BRIEFFORGE_ACCESS_PASSWORD=
BRIEFFORGE_SESSION_SECRET=
